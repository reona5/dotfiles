{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Bash(sudo:*)"
    ],
    "ask": []
  },
  "language": "japanese",
  "skipDangerousModePermissionPrompt": true
}
